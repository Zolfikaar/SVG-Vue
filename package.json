{
  "name": "svg-to-vue",
  "displayName": "SVG to Vue",
  "description": "Generate a centralized Vue icon system from SVG files (registry + Icon component). [Try the Web Version](https://svg-to-vue.app)",
  "version": "0.0.1",
  "publisher": "Tholfikar Matar",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zolfikaar/SVG-Vue"
  },
  "icon": "assets/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:svg-to-vue.generateComponents"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svg-to-vue.generateComponents",
        "title": "SVG to Vue: Generate Icon System",
        "category": "SVG to Vue"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "svg-to-vue.generateComponents",
          "when": "true"
        }
      ],
      "explorer/context": [
        {
          "command": "svg-to-vue.generateComponents",
          "group": "navigation@9",
          "when": "resourceDirname"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/svg-path-bbox": "^1.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "svg-path-bbox": "^2.1.0",
    "svgo": "^4.0.1",
    "svgpath": "^2.6.0"
  }
}